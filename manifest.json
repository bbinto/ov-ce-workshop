{
  "manifest_version": 3,
  "name": "Officevibe AI Assistant",
  "version": "1.0.0",
  "description": "Injects AI-powered suggestions into Officevibe feedback pages",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://officevibe.workleap.com/*",
    "https://api.anthropic.com/*",
    "https://slack.com/*",
    "https://www.glassdoor.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://officevibe.workleap.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
